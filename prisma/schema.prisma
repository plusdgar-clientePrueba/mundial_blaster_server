generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model usuarios {
  id             String            @id @default(dbgenerated("('usr_'::text || substr(md5((random())::text), 1, 24))")) @db.VarChar(36)
  nombre         String            @db.VarChar(255)
  email          String            @unique @db.VarChar(255)
  password_hash  String            @db.VarChar(255)
  fecha_creacion DateTime?         @default(now()) @db.Timestamptz(6)
  lineas_whatsapp lineas_whatsapp[]
  campaigns      campaigns[]        @relation("UsuarioCampaigns")
  campaign_logs  campaign_logs[]    @relation("UsuarioCampaignLogs")
}

model lineas_whatsapp {
  id             String    @id @default(dbgenerated("('line_'::text || substr(md5((random())::text), 1, 24))")) @db.VarChar(36)
  userId         String    @db.VarChar(36)
  phone          String    @unique @db.VarChar(20)
  nombre         String    @default("Línea") @db.VarChar(255)
  status         String    @default("PENDING") @db.VarChar(20)
  fecha_creacion DateTime? @default(now()) @db.Timestamptz(6)
  usuarios       usuarios  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model campaigns {
  id            String          @id
  name          String
  template      String
  status        String?         @default("draft")
  total_targets Int?            @default(0)
  sent_count    Int?            @default(0)
  failed_count  Int?            @default(0)
  owner_id      String
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  usuario       usuarios        @relation("UsuarioCampaigns", fields: [owner_id], references: [id], onDelete: Cascade)
  campaign_logs campaign_logs[] @relation("CampaignLogs")
}

model campaign_logs {
  id            Int       @id @default(autoincrement())
  campaign_id   String
  contact_phone String
  status        String?
  line_id       String?
  sent_at       DateTime? @default(now()) @db.Timestamptz(6)
  owner_id      String
  campaign      campaigns @relation("CampaignLogs", fields: [campaign_id], references: [id], onDelete: Cascade)
  usuario       usuarios  @relation("UsuarioCampaignLogs", fields: [owner_id], references: [id], onDelete: Cascade)
}