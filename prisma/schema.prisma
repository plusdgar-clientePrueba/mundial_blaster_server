generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model app_config {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model usuarios {
  id         String   @id @default(cuid())
  nombre     String
  email      String   @unique
  avatar     String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model lineas_whatsapp {
  id             String   @id @default(cuid())
  phone          String   @unique
  nombre         String?
  status         String   @default("DESCONECTADA")
  userId         String?
  is_archived    Boolean  @default(false)
  fecha_creacion DateTime @default(now())
  chatbot_id     String?
}

model campaigns {
  id          String   @id @default(cuid())
  name        String
  line_id     String
  message     String
  image_url   String?
  total       Int
  sent        Int      @default(0)
  failed      Int      @default(0)
  status      String   @default("running")
  created_at  DateTime @default(now())
  finished_at DateTime?
}

model campaign_logs {
  id            Int      @id @default(autoincrement())
  campaign_id   String
  contact_phone String
  status        String
  line_id       String
  owner_id      String
  sent_at       DateTime?
}